OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-v4-flash

# local: 完整个人工具；demo: 匿名隔离演示（外部 AI 禁用）；test: 自动化测试
APP_MODE=local
# 留空时使用 data/internpilot.db；测试和自定义部署可覆盖
INTERNPILOT_DB_PATH=
# 浏览器辅助 URL 导入；配置目录必须保持在 Git 忽略范围内
INTERNPILOT_BROWSER_PROFILE_DIR=data/browser_profile
INTERNPILOT_BROWSER_TIMEOUT=150
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
